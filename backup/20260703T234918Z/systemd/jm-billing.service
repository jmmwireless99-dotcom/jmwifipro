[Unit]
Description=JM WIFI NETWORK Billing Panel
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/jm-billing
Environment=PORT=3000
EnvironmentFile=-/opt/jm-billing/.env
ExecStart=/usr/bin/node /opt/jm-billing/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
